# API Key da Anthropic (obrigatório)
ANTHROPIC_API_KEY=

# Modelo do Claude a ser usado (opcional, default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Diretório onde salvar os sumários gerados (opcional)
OUTPUT_DIR=/path/to/your/meeting-summaries

# Idioma da transcrição e do sumário (opcional, default: pt-br)
LANGUAGE=pt-br

# Máximo de tokens na resposta (opcional, default: 4096)
MAX_TOKENS=4096
